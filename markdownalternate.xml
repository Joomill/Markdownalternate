<?xml version="1.0" encoding="UTF-8"?>
<extension type="plugin" group="system" method="upgrade">
    <name>PLG_SYSTEM_MARKDOWNALTERNATE</name>
    <description>PLG_SYSTEM_MARKDOWNALTERNATE_XML_DESCRIPTION</description>
    <author>Jeroen Moolenschot | Joomill</author>
    <authorEmail>info@joomill.nl</authorEmail>
    <authorUrl>https://www.joomill-extensions.com</authorUrl>
    <license>GNU General Public License version 3 or later</license>
    <creationDate>June 2026</creationDate>
    <copyright>(C) 2026 Joomill Extensions</copyright>
    <version>1.3.0</version>
    <namespace path="src">Joomill\Plugin\System\Markdownalternate</namespace>

    <!-- Files -->
    <files>
        <folder plugin="markdownalternate">services</folder>
        <folder>src</folder>
        <folder>language</folder>
        <filename>markdownalternate.xml</filename>
    </files>

    <!-- Config / Params -->
    <config>
        <fields name="params">
            <fieldset name="basic">
                <field
                    name="show_category"
                    type="radio"
                    label="PLG_SYSTEM_MARKDOWNALTERNATE_FIELD_SHOW_CATEGORY_LABEL"
                    default="1"
                    layout="joomla.form.field.radio.switcher"
                >
                    <option value="0">JNO</option>
                    <option value="1">JYES</option>
                </field>
                <field
                    name="show_tags"
                    type="radio"
                    label="PLG_SYSTEM_MARKDOWNALTERNATE_FIELD_SHOW_TAGS_LABEL"
                    default="1"
                    layout="joomla.form.field.radio.switcher"
                >
                    <option value="0">JNO</option>
                    <option value="1">JYES</option>
                </field>
                <field
                    name="show_author"
                    type="radio"
                    label="PLG_SYSTEM_MARKDOWNALTERNATE_FIELD_SHOW_AUTHOR_LABEL"
                    default="1"
                    layout="joomla.form.field.radio.switcher"
                >
                    <option value="0">JNO</option>
                    <option value="1">JYES</option>
                </field>
                <field
                    name="show_date"
                    type="radio"
                    label="PLG_SYSTEM_MARKDOWNALTERNATE_FIELD_SHOW_DATE_LABEL"
                    default="1"
                    layout="joomla.form.field.radio.switcher"
                >
                    <option value="0">JNO</option>
                    <option value="1">JYES</option>
                </field>
                <field
                    name="show_description"
                    type="radio"
                    label="PLG_SYSTEM_MARKDOWNALTERNATE_FIELD_SHOW_DESCRIPTION_LABEL"
                    default="1"
                    layout="joomla.form.field.radio.switcher"
                >
                    <option value="0">JNO</option>
                    <option value="1">JYES</option>
                </field>
                <field
                    name="show_images"
                    type="radio"
                    label="PLG_SYSTEM_MARKDOWNALTERNATE_FIELD_SHOW_IMAGES_LABEL"
                    default="1"
                    layout="joomla.form.field.radio.switcher"
                >
                    <option value="0">JNO</option>
                    <option value="1">JYES</option>
                </field>
                <field
                    name="show_fields"
                    type="radio"
                    label="PLG_SYSTEM_MARKDOWNALTERNATE_FIELD_SHOW_FIELDS_LABEL"
                    default="1"
                    layout="joomla.form.field.radio.switcher"
                >
                    <option value="0">JNO</option>
                    <option value="1">JYES</option>
                </field>
                <field
                    name="show_link"
                    type="radio"
                    label="PLG_SYSTEM_MARKDOWNALTERNATE_FIELD_SHOW_LINK_LABEL"
                    default="1"
                    layout="joomla.form.field.radio.switcher"
                >
                    <option value="0">JNO</option>
                    <option value="1">JYES</option>
                </field>
                <field
                    name="alternate_url_format"
                    type="list"
                    label="PLG_SYSTEM_MARKDOWNALTERNATE_FIELD_ALTERNATE_URL_FORMAT_LABEL"
                    description="PLG_SYSTEM_MARKDOWNALTERNATE_FIELD_ALTERNATE_URL_FORMAT_DESC"
                    default="md"
                    showon="show_link:1"
                >
                    <option value="md">PLG_SYSTEM_MARKDOWNALTERNATE_FIELD_ALTERNATE_URL_FORMAT_OPTION_MD</option>
                    <option value="query">PLG_SYSTEM_MARKDOWNALTERNATE_FIELD_ALTERNATE_URL_FORMAT_OPTION_QUERY</option>
                </field>
                <field
                    name="render_shortcodes"
                    type="radio"
                    label="PLG_SYSTEM_MARKDOWNALTERNATE_FIELD_RENDER_SHORTCODES_LABEL"
                    description="PLG_SYSTEM_MARKDOWNALTERNATE_FIELD_RENDER_SHORTCODES_DESC"
                    default="0"
                    layout="joomla.form.field.radio.switcher"
                >
                    <option value="0">JNO</option>
                    <option value="1">JYES</option>
                </field>
                <field
                    name="shortcode_plugins"
                    type="text"
                    label="PLG_SYSTEM_MARKDOWNALTERNATE_FIELD_SHORTCODE_PLUGINS_LABEL"
                    description="PLG_SYSTEM_MARKDOWNALTERNATE_FIELD_SHORTCODE_PLUGINS_DESC"
                    default="loadmodule,loadposition"
                    showon="render_shortcodes:1"
                />
            </fieldset>
        </fields>
    </config>

    <!-- Changelog -->
    <changelogurl>
        <![CDATA[https://www.joomill-extensions.com/index.php?option=com_ochsubscriptions&amp;view=changelog&amp;format=xml&amp;cat=33]]>
    </changelogurl>

    <!-- Updateserver -->
    <updateservers>
        <server type="extension" priority="1" name="Joomill Markdown Alternate plugin">
            <![CDATA[https://www.joomill-extensions.com/index.php?option=com_ochsubscriptions&amp;view=updater&amp;format=xml&amp;cat=33]]>
        </server>
    </updateservers>

</extension>
